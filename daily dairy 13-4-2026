<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JavaScript Conditional Statements</title>
</head>
<body>

    <h2>JavaScript Conditional Statements Demo</h2>

    <hr>

    <!-- IF statement -->
    <h3>If Statement</h3>
    <button onclick="checkIf()">Run If</button>
    <p id="ifResult"></p>

    <hr>

    <!-- IF-ELSE statement -->
    <h3>If-Else Statement</h3>
    <button onclick="checkIfElse()">Run If-Else</button>
    <p id="ifElseResult"></p>

    <hr>

    <!-- SWITCH statement -->
    <h3>Switch Statement</h3>
    <button onclick="checkSwitch()">Run Switch</button>
    <p id="switchResult"></p>

    <script>
        // IF statement example
        function checkIf() {
            let a = 10;

            if (a > 5) {
                document.getElementById("ifResult").innerText = "a is greater than 5";
            }
        }

        // IF-ELSE statement example
        function checkIfElse() {
            let age = 15;

            if (age >= 18) {
                document.getElementById("ifElseResult").innerText = "You are an Adult";
            } else {
                document.getElementById("ifElseResult").innerText = "You are a Minor";
            }
        }

        // SWITCH statement example
        function checkSwitch() {
            let day = 3;
            let result;

            switch (day) {
                case 1:
                    result = "Monday";
                    break;
                case 2:
                    result = "Tuesday";
                    break;
                case 3:
                    result = "Wednesday";
                    break;
                case 4:
                    result = "Thursday";
                    break;
                default:
                    result = "Invalid Day";
            }

            document.getElementById("switchResult").innerText = result;
        }
    </script>

</body>
</html>


  
  
