  <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>String and String Methods</title>
</head>
<body>

    <h2>JavaScript String & String Methods</h2>

    <hr>

    <!-- STRING METHODS DEMO -->
    <button onclick="stringMethods()">Run String Methods</button>

    <p id="original"></p>
    <p id="length"></p>
    <p id="upper"></p>
    <p id="lower"></p>
    <p id="slice"></p>
    <p id="replace"></p>
    <p id="trim"></p>

    <script>
        function stringMethods() {
            let text = "  Hello JavaScript World  ";

            // original string
            document.getElementById("original").innerText = "Original: " + text;

            // length
            document.getElementById("length").innerText = "Length: " + text.length;

            // uppercase
            document.getElementById("upper").innerText = "Uppercase: " + text.toUpperCase();

            // lowercase
            document.getElementById("lower").innerText = "Lowercase: " + text.toLowerCase();

            // slice
            document.getElementById("slice").innerText = "Slice (6-16): " + text.slice(6, 16);

            // replace
            document.getElementById("replace").innerText = "Replace: " + text.replace("JavaScript", "JS");

            // trim
            document.getElementById("trim").innerText = "Trim: " + text.trim();
        }
    </script>

</body>
</html>
