  <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JavaScript Loops Example</title>
</head>
<body>

    <h2>JavaScript Loops Demo</h2>

    <hr>

    <!-- FOR LOOP -->
    <h3>For Loop (1 to 5)</h3>
    <button onclick="forLoop()">Run For Loop</button>
    <p id="forResult"></p>

    <hr>

    <!-- WHILE LOOP -->
    <h3>While Loop (1 to 5)</h3>
    <button onclick="whileLoop()">Run While Loop</button>
    <p id="whileResult"></p>

    <hr>

    <!-- DO WHILE LOOP -->
    <h3>Do...While Loop (1 to 5)</h3>
    <button onclick="doWhileLoop()">Run Do While Loop</button>
    <p id="doWhileResult"></p>

    <script>
        // FOR LOOP
        function forLoop() {
            let text = "";

            for (let i = 1; i <= 5; i++) {
                text += i + " ";
            }

            document.getElementById("forResult").innerText = text;
        }

        // WHILE LOOP
        function whileLoop() {
            let text = "";
            let i = 1;

            while (i <= 5) {
                text += i + " ";
                i++;
            }

            document.getElementById("whileResult").innerText = text;
        }

        // DO WHILE LOOP
        function doWhileLoop() {
            let text = "";
            let i = 1;

            do {
                text += i + " ";
                i++;
            } while (i <= 5);

            document.getElementById("doWhileResult").innerText = text;
        }
    </script>

</body>
</html>
